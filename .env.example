# Unified environment variable template for future real-model integration.
# Copy this file to `.env` when a chapter starts calling external model services.

# Select the provider and model names explicitly so examples keep a stable interface
# even if the underlying SDK or vendor changes later.
MODEL_PROVIDER=openai
MODEL_NAME=your-chat-model
EMBEDDING_MODEL_NAME=your-embedding-model

# Provider credentials.
OPENAI_API_KEY=your-openai-api-key

# Optional: override the compatible API endpoint when using a proxy or self-hosted gateway.
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: tracing/observability for later chapters such as evaluation and debugging.
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
